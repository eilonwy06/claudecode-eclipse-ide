<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

   <!-- Claude Code View -->
   <extension point="org.eclipse.ui.views">
      <category
            id="com.anthropic.claudecode.eclipse.category"
            name="Claude Code"/>
      <view
            id="com.anthropic.claudecode.eclipse.ui.ClaudeCodeView"
            name="Claude Code"
            icon="icons/claude-16.png"
            class="com.anthropic.claudecode.eclipse.ui.ClaudeCodeView"
            category="com.anthropic.claudecode.eclipse.category"
            allowMultiple="false"
            restorable="true"/>
      <view
            id="com.anthropic.claudecode.eclipse.ui.ClaudeChatView"
            name="Claude Chat"
            icon="icons/claude-16.png"
            class="com.anthropic.claudecode.eclipse.ui.ClaudeChatView"
            category="com.anthropic.claudecode.eclipse.category"
            allowMultiple="false"
            restorable="true"/>
      <view
            id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"
            name="Claude CLI"
            icon="icons/claude-16.png"
            class="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"
            category="com.anthropic.claudecode.eclipse.category"
            allowMultiple="false"
            restorable="true"/>
   </extension>

   <!-- Commands -->
   <extension point="org.eclipse.ui.commands">
      <category
            id="com.anthropic.claudecode.eclipse.commands.category"
            name="Claude Code"/>
      <command
            id="com.anthropic.claudecode.eclipse.commands.toggle"
            name="Toggle Claude Code"
            description="Toggle the Claude Code terminal panel"
            categoryId="com.anthropic.claudecode.eclipse.commands.category"/>
      <command
            id="com.anthropic.claudecode.eclipse.commands.sendSelection"
            name="Send Selection to Claude"
            description="Send the current editor selection to Claude Code"
            categoryId="com.anthropic.claudecode.eclipse.commands.category"/>
      <command
            id="com.anthropic.claudecode.eclipse.commands.addFile"
            name="Add File to Claude Context"
            description="Add the current file to Claude Code context"
            categoryId="com.anthropic.claudecode.eclipse.commands.category"/>
      <command
            id="com.anthropic.claudecode.eclipse.commands.resume"
            name="Resume Claude Code"
            description="Resume the last Claude Code session"
            categoryId="com.anthropic.claudecode.eclipse.commands.category"/>
      <command
            id="com.anthropic.claudecode.eclipse.commands.restart"
            name="Restart Claude Code Server"
            description="Restart the MCP server"
            categoryId="com.anthropic.claudecode.eclipse.commands.category"/>
   </extension>

   <!-- Command Handlers -->
   <extension point="org.eclipse.ui.handlers">
      <handler
            commandId="com.anthropic.claudecode.eclipse.commands.toggle"
            class="com.anthropic.claudecode.eclipse.ui.handlers.ToggleClaudeHandler"/>
      <handler
            commandId="com.anthropic.claudecode.eclipse.commands.sendSelection"
            class="com.anthropic.claudecode.eclipse.ui.handlers.SendSelectionHandler"/>
      <handler
            commandId="com.anthropic.claudecode.eclipse.commands.addFile"
            class="com.anthropic.claudecode.eclipse.ui.handlers.AddFileHandler"/>
      <handler
            commandId="com.anthropic.claudecode.eclipse.commands.resume"
            class="com.anthropic.claudecode.eclipse.ui.handlers.ResumeClaudeHandler"/>
      <handler
            commandId="com.anthropic.claudecode.eclipse.commands.restart"
            class="com.anthropic.claudecode.eclipse.ui.handlers.RestartServerHandler"/>
   </extension>

   <!-- Key Bindings -->
   <extension point="org.eclipse.ui.bindings">
      <key
            commandId="com.anthropic.claudecode.eclipse.commands.toggle"
            schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
            sequence="M1+M2+C"/>
      <key
            commandId="com.anthropic.claudecode.eclipse.commands.sendSelection"
            schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
            sequence="M1+M2+S"/>
      <key
            commandId="com.anthropic.claudecode.eclipse.commands.addFile"
            schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
            sequence="M1+M3+A"/>
   </extension>

   <!-- Menus and Toolbar -->
   <extension point="org.eclipse.ui.menus">
      <!-- Main menu contribution -->
      <menuContribution locationURI="menu:org.eclipse.ui.main.menu?after=additions">
         <menu
               id="com.anthropic.claudecode.eclipse.menu"
               label="Claude Code"
               mnemonic="C">
            <command
                  commandId="com.anthropic.claudecode.eclipse.commands.toggle"
                  label="Toggle Claude Code"
                  mnemonic="T"
                  style="push"/>
            <command
                  commandId="com.anthropic.claudecode.eclipse.commands.sendSelection"
                  label="Send Selection to Claude"
                  mnemonic="S"
                  style="push"/>
            <command
                  commandId="com.anthropic.claudecode.eclipse.commands.addFile"
                  label="Add File to Claude Context"
                  mnemonic="A"
                  style="push"/>
            <separator name="com.anthropic.claudecode.eclipse.separator1" visible="true"/>
            <command
                  commandId="com.anthropic.claudecode.eclipse.commands.resume"
                  label="Resume Session"
                  mnemonic="R"
                  style="push"/>
            <command
                  commandId="com.anthropic.claudecode.eclipse.commands.restart"
                  label="Restart Server"
                  style="push"/>
         </menu>
      </menuContribution>

      <!-- Editor context menu -->
      <menuContribution locationURI="popup:#TextEditorContext?after=additions">
         <menu
               id="com.anthropic.claudecode.eclipse.editorMenu"
               label="Claude Code">
            <command
                  commandId="com.anthropic.claudecode.eclipse.commands.sendSelection"
                  label="Send Selection to Claude"
                  style="push"/>
            <command
                  commandId="com.anthropic.claudecode.eclipse.commands.addFile"
                  label="Add File to Claude Context"
                  style="push"/>
         </menu>
      </menuContribution>

      <!-- Toolbar -->
      <menuContribution locationURI="toolbar:org.eclipse.ui.main.toolbar?after=additions">
         <toolbar id="com.anthropic.claudecode.eclipse.toolbar">
            <command
                  commandId="com.anthropic.claudecode.eclipse.commands.toggle"
                  icon="icons/claude-16.png"
                  label="Toggle Claude Code"
                  style="push"
                  tooltip="Toggle Claude Code (Ctrl+Shift+C)"/>
         </toolbar>
      </menuContribution>
   </extension>

   <!-- Preferences -->
   <extension point="org.eclipse.ui.preferencePages">
      <page
            id="com.anthropic.claudecode.eclipse.preferences"
            name="Claude Code"
            class="com.anthropic.claudecode.eclipse.ui.ClaudePreferencePage"/>
   </extension>

   <!-- Preference Initializer -->
   <extension point="org.eclipse.core.runtime.preferences">
      <initializer class="com.anthropic.claudecode.eclipse.ui.ClaudePreferenceInitializer"/>
   </extension>

   <!-- Startup hook -->
   <extension point="org.eclipse.ui.startup">
      <startup class="com.anthropic.claudecode.eclipse.ClaudeStartup"/>
   </extension>

   <!-- Register Claude CLI in Show In menu (Package Explorer works, Project Explorer is CNF limitation) -->
   <extension point="org.eclipse.ui.perspectiveExtensions">
      <!-- Java -->
      <perspectiveExtension targetID="org.eclipse.jdt.ui.JavaPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <perspectiveExtension targetID="org.eclipse.jdt.ui.JavaBrowsingPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <perspectiveExtension targetID="org.eclipse.jdt.ui.JavaHierarchyPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- Java EE / Jakarta EE -->
      <perspectiveExtension targetID="org.eclipse.jst.j2ee.J2EEPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <perspectiveExtension targetID="org.eclipse.jst.jee.ui.J2EEPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <perspectiveExtension targetID="org.eclipse.wst.web.ui.J2EEPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- Resource -->
      <perspectiveExtension targetID="org.eclipse.ui.resourcePerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <perspectiveExtension targetID="org.eclipse.rse.ui.view.SystemPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- Debug -->
      <perspectiveExtension targetID="org.eclipse.debug.ui.DebugPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- Plug-in Development -->
      <perspectiveExtension targetID="org.eclipse.pde.ui.PDEPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- Team / Git -->
      <perspectiveExtension targetID="org.eclipse.team.ui.TeamSynchronizingPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <perspectiveExtension targetID="org.eclipse.egit.ui.GitRepositoryExploring">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- C/C++ -->
      <perspectiveExtension targetID="org.eclipse.cdt.ui.CPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- Web / JavaScript / TypeScript -->
      <perspectiveExtension targetID="org.eclipse.wst.jsdt.ui.JavaScriptPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <perspectiveExtension targetID="org.eclipse.wst.web.ui.webDevPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <perspectiveExtension targetID="org.eclipse.wst.xml.ui.perspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <perspectiveExtension targetID="org.eclipse.wildwebdeveloper.perspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <perspectiveExtension targetID="org.eclipse.wildwebdeveloper.web">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- Node.js / Nodeclipse / Enide -->
      <perspectiveExtension targetID="org.nodeclipse.ui.perspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <perspectiveExtension targetID="org.nodeclipse.enide.studio.perspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <perspectiveExtension targetID="org.nodeclipse.perspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- PHP -->
      <perspectiveExtension targetID="org.eclipse.php.perspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- Python -->
      <perspectiveExtension targetID="org.python.pydev.ui.PythonPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <perspectiveExtension targetID="org.python.pydev.debug.ui.DebugPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- Database / SQL -->
      <perspectiveExtension targetID="org.eclipse.datatools.sqltools.sqleditor.perspectives.EditorPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <perspectiveExtension targetID="org.eclipse.datatools.connectivity.DataSourceExplorerNavigator">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- Spring -->
      <perspectiveExtension targetID="com.springsource.sts.ide.perspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <perspectiveExtension targetID="org.springframework.ide.eclipse.perspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- Groovy / Grails -->
      <perspectiveExtension targetID="org.codehaus.groovy.eclipse.perspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <perspectiveExtension targetID="com.springsource.sts.grails.perspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- Scala -->
      <perspectiveExtension targetID="org.scala-ide.sdt.core.perspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- Kotlin -->
      <perspectiveExtension targetID="org.jetbrains.kotlin.perspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- Ruby -->
      <perspectiveExtension targetID="org.eclipse.dltk.ruby.ui.RubyPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- Rust -->
      <perspectiveExtension targetID="org.eclipse.corrosion.perspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
      <!-- Go -->
      <perspectiveExtension targetID="com.googlecode.goclipse.perspectives.GoPerspective">
         <showInPart id="com.anthropic.claudecode.eclipse.ui.ClaudeCliView"/>
      </perspectiveExtension>
   </extension>

   <!-- Open Claude CLI Here - context menu for navigators -->
   <extension point="org.eclipse.ui.popupMenus">
      <objectContribution
            id="com.anthropic.claudecode.eclipse.openCliHere"
            objectClass="org.eclipse.core.resources.IResource"
            adaptable="true">
         <action
               id="com.anthropic.claudecode.eclipse.actions.openCliHere"
               label="Open Claude CLI Here"
               icon="icons/claude-16.png"
               class="com.anthropic.claudecode.eclipse.ui.actions.OpenCliHereAction"/>
      </objectContribution>
   </extension>

</plugin>
