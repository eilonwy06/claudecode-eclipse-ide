Manifest-Version: 1.0
Bundle-ManifestVersion: 2
Bundle-Name: Claude Code for Eclipse
Bundle-SymbolicName: com.anthropic.claudecode.eclipse;singleton:=true
Bundle-Version: 1.1.1.qualifier
Bundle-Activator: com.anthropic.claudecode.eclipse.Activator
Bundle-Vendor: eilonwy06
Require-Bundle: org.eclipse.ui,
 org.eclipse.core.runtime,
 org.eclipse.core.resources,
 org.eclipse.core.filesystem,
 org.eclipse.ui.editors,
 org.eclipse.ui.ide,
 org.eclipse.ui.console,
 org.eclipse.ui.workbench.texteditor,
 org.eclipse.jface.text,
 org.eclipse.compare,
 org.eclipse.debug.ui,
 com.google.gson,
 com.sun.jna,
 com.sun.jna.platform
Bundle-ClassPath: .,
 lib/pty4j-0.12.35.jar,
 lib/jediterm-pty-2.67.jar,
 lib/annotations-24.1.0.jar
Bundle-RequiredExecutionEnvironment: JavaSE-21
Automatic-Module-Name: com.anthropic.claudecode.eclipse
Bundle-ActivationPolicy: lazy
Export-Package: com.anthropic.claudecode.eclipse,
 com.anthropic.claudecode.eclipse.mcp,
 com.anthropic.claudecode.eclipse.server
